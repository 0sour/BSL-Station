<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.Setting.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starward.Language"
             xmlns:local="using:Starward.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Page.Resources>
        <FontFamily x:Key="XboxFluent2">ms-appx:///Assets/Font/XboxFluent2.ttf#Xbox Fluent v2</FontFamily>
    </Page.Resources>

    <Grid>

        <NavigationView IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        ItemInvoked="NavigationView_ItemInvoked"
                        OpenPaneLength="260"
                        PaneDisplayMode="Left">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewHeaderMargin">0</Thickness>
                <x:Double x:Key="PaneToggleButtonHeight">0</x:Double>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <TextBlock Margin="16,12,0,8"
                           FontSize="20"
                           FontWeight="Bold"
                           Text="BSL 设置" />
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!--  启动器与体验  -->
                <NavigationViewItem Content="启动器与体验"
                                    IsSelected="True"
                                    Tag="GeneralSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  游戏安装与下载  -->
                <NavigationViewItem Content="游戏安装与下载" Tag="DownloadSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEBD3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  文件、缓存与数据  -->
                <NavigationViewItem Content="文件、缓存与数据" Tag="FileManageSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  截图与图像  -->
                <NavigationViewItem Content="截图与图像" Tag="ScreenshotSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE91B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  快捷键  -->
                <NavigationViewItem Content="快捷键" Tag="HotkeySetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  手柄与输入  -->
                <NavigationViewItem Content="手柄与输入" Tag="GamepadControlSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource XboxFluent2}" Glyph="&#xE9CD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <!--  工具与辅助功能  -->
                <NavigationViewItem Content="工具与辅助功能" Tag="ToolboxSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC7A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  高级与调试  -->
                <NavigationViewItem Content="高级与调试" Tag="AdvancedSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA86;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <!--  关于 BSL Station  -->
                <NavigationViewItem Content="关于 BSL Station" Tag="AboutSetting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame Name="Frame_Setting" Margin="24,24,0,0" />

        </NavigationView>

    </Grid>

</sf:PageBase>
