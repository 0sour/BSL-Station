<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.Setting.GeneralSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starward.Language"
             xmlns:local="using:Starward.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             xmlns:sfv="using:Starward.Features.ViewHost"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="0,0,24,0">


            <!--  语言  -->
            <TextBlock FontSize="20" Text="语言" />
            <ComboBox Name="ComboBox_Language"
                      Height="36"
                      MinWidth="260"
                      Margin="0,12,0,0"
                      Padding="18.5,0,0,0"
                      BorderThickness="0"
                      CornerRadius="8,18,18,8"
                      SelectionChanged="ComboBox_Language_SelectionChanged" />

            <!--  游戏选择器  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="游戏选择器" />
            <ToggleSwitch Margin="0,12,0,0"
                          IsOn="{x:Bind BslIsGameSelectorPinned, Mode=TwoWay}"
                          OffContent="固定左上角游戏选择栏"
                          OnContent="固定左上角游戏选择栏" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="关闭后，游戏选择栏只会在鼠标移到左上角时展开。"
                       TextWrapping="Wrap" />

            <!--  游戏公告  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="游戏信息与公告" />
            <ToggleSwitch Margin="0,12,0,0"
                          IsOn="{x:Bind EnableBannerAndPost, Mode=TwoWay}"
                          OffContent="显示游戏信息区公告与活动内容"
                          OnContent="显示游戏信息区公告与活动内容" />
            <ToggleSwitch Margin="0,8,0,0"
                          IsEnabled="{x:Bind EnableBannerAndPost}"
                          IsOn="{x:Bind DisableGameNoticeRedHot, Mode=TwoWay}"
                          OffContent="显示公告红点提醒"
                          OnContent="隐藏公告红点提醒" />

            <!--  启动游戏后  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="启动游戏后" />
            <ComboBox Height="36"
                      MinWidth="260"
                      Margin="0,12,0,0"
                      Padding="18.5,0,0,0"
                      BorderThickness="0"
                      CornerRadius="8"
                      SelectedIndex="{x:Bind StartGameAction, Mode=TwoWay}">
                <ComboBoxItem Content="不执行操作" />
                <ComboBoxItem Content="最小化到任务栏" />
                <ComboBoxItem Content="最小化到系统托盘" />
            </ComboBox>

            <!--  窗口关闭选项  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="关闭主窗口时" />
            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="24">
                <RadioButton Name="RadioButton_CloseWindowOption_Hide"
                             Checked="RadioButton_CloseWindowOption_Checked"
                             Content="最小化到系统托盘"
                             GroupName="CloseWindowOption"
                             Tag="{x:Bind sfv:MainWindowCloseOption.Hide}" />
                <RadioButton Name="RadioButton_CloseWindowOption_Exit"
                             Checked="RadioButton_CloseWindowOption_Checked"
                             Content="直接退出"
                             GroupName="CloseWindowOption"
                             Tag="{x:Bind sfv:MainWindowCloseOption.Exit}" />
            </StackPanel>

            <ToggleSwitch Margin="0,12,0,0"
                          IsOn="{x:Bind EnableGameAccountSwitcher, Mode=TwoWay}"
                          OffContent="启用基于注册表的游戏账号切换"
                          OnContent="启用基于注册表的游戏账号切换" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="仅在当前游戏支持账号切换时显示入口。"
                       TextWrapping="Wrap" />


            <MenuFlyoutSeparator Margin="0,20,0,0" />

            <!--  透明/动画效果  -->
            <TextBlock Margin="0,20,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="为了获得更自然的窗口透明和过渡动画，请在 Windows 系统设置中启用以下视觉效果。"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left">
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="透明效果" />
                </Hyperlink>
                <Run Text="" />
                <Run Text="" />
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="动画效果" />
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
