<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.Setting.FileManageSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starward.Language"
             xmlns:local="using:Starward.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="using:Starward"
             xmlns:sf="using:Starward.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>


            <!--  用户数据文件夹  -->
            <TextBlock FontSize="20" Text="BSL 数据文件夹" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="这里保存游戏路径、下载历史、设置、数据库备份等本地数据。重新选择前请先手动迁移原目录。"
                       TextWrapping="Wrap" />
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  重新选择  -->
                <Button Grid.Column="0"
                        Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ChangeUserDataFolderCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DE;" />
                        <TextBlock Text="重新选择数据文件夹" />
                    </StackPanel>
                </Button>
                <!--  当前用户数据文件夹  -->
                <Button Grid.Column="1"
                        Height="40"
                        Margin="16,0,0,0"
                        Padding="20,0,20,1"
                        BorderThickness="0"
                        Command="{x:Bind OpenUserDataFolderCommand}"
                        CornerRadius="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextTrimmedChanged="TextBlock_IsTextTrimmedChanged"
                                   MaxLines="2"
                                   Text="{x:Bind s:AppConfig.UserDataFolder}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />
                        <FontIcon Grid.Column="1"
                                  Margin="0,2,2,0"
                                  FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;" />
                    </Grid>
                </Button>
            </Grid>


            <!--  备份数据库  -->
            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="16">
                <Button Height="40"
                        Margin="0,0,0,0"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind BackupDatabaseCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xF413;" />
                        <TextBlock Text="备份本地数据库" />
                    </StackPanel>
                </Button>
                <ProgressRing Width="28"
                              Height="28"
                              IsIndeterminate="{x:Bind BackupDatabaseCommand.IsRunning}"
                              Visibility="{x:Bind BackupDatabaseCommand.IsRunning}" />
                <Button Height="40"
                        Padding="20,0,20,1"
                        BorderThickness="0"
                        Command="{x:Bind OpenLastBackupDatabaseCommand}"
                        CornerRadius="20"
                        Visibility="{x:Bind LastDatabaseBackupTime, Converter={StaticResource ObjectToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind LastDatabaseBackupTime}" />
                        <FontIcon Margin="8,2,2,0"
                                  FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;" />
                    </StackPanel>
                </Button>
            </StackPanel>


            <!--  删除所有设置  -->
            <Button Height="40"
                    Margin="0,8,0,0"
                    Padding="16,0,16,0"
                    BorderThickness="0"
                    Command="{x:Bind DeleteAllSettingCommand}"
                    CornerRadius="8,20,20,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" />
                    <TextBlock Text="删除所有设置" />
                </StackPanel>
            </Button>


            <!--  日志  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="日志" />
            <!--  打开日志文件夹  -->
            <Button Height="40"
                    Margin="0,8,0,0"
                    Padding="16,0,16,0"
                    BorderThickness="0"
                    Command="{x:Bind OpenLogFolderCommand}"
                    CornerRadius="8,20,20,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE838;" />
                    <TextBlock Text="打开日志文件夹" />
                </StackPanel>
            </Button>


            <!--  缓存  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="缓存" />
            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="20">
                <TextBlock>
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="日志" />
                    <LineBreak />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="图片缓存" />
                    <LineBreak />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="浏览器缓存" />
                    <LineBreak />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="游戏资源缓存" />
                    <LineBreak />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="启动器背景文件" />
                </TextBlock>
                <TextBlock>
                    <Run Text="{x:Bind LogCacheSize}" />
                    <LineBreak />
                    <Run Text="{x:Bind ImageCacheSize}" />
                    <LineBreak />
                    <Run Text="{x:Bind WebCacheSize}" />
                    <LineBreak />
                    <Run Text="{x:Bind GameCacheSize}" />
                    <LineBreak />
                    <Run Text="{x:Bind LauncherBackgroundSize}" />
                </TextBlock>
            </StackPanel>
            <!--  清理缓存  -->
            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="16">
                <Button Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ClearCacheCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEA99;" />
                        <TextBlock Text="清理缓存" />
                    </StackPanel>
                </Button>
                <ProgressRing Width="28"
                              Height="28"
                              VerticalAlignment="Center"
                              IsIndeterminate="{x:Bind ClearCacheCommand.IsRunning}"
                              Visibility="{x:Bind ClearCacheCommand.IsRunning}" />
            </StackPanel>
            <!--  清理启动器背景文件  -->
            <CheckBox Margin="0,4,0,0"
                      Content="同时清理自动下载的启动器背景图片/视频"
                      IsChecked="{x:Bind ClearLauncherBackground, Mode=TwoWay}" />



        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
