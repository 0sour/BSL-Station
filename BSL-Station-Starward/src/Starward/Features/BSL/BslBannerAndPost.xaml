<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Starward.Features.BSL.BslBannerAndPost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="using:Starward.Features.BSL.Models"
             mc:Ignorable="d">

    <UserControl.OpacityTransition>
        <ScalarTransition />
    </UserControl.OpacityTransition>

    <Grid x:Name="Grid_BannerAndPost"
          Width="380"
          Height="304"
          Background="{ThemeResource CustomAcrylicBrush}"
          CornerRadius="8"
          RowSpacing="4"
          Shadow="{StaticResource ThemeShadow}"
          Translation="0,0,16">

        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row_Banner" Height="176" />
            <RowDefinition x:Name="Row_Post" Height="124" />
        </Grid.RowDefinitions>

        <Grid PointerEntered="Grid_BannerContainer_PointerEntered"
              PointerExited="Grid_BannerContainer_PointerExited">
            <FlipView x:Name="FlipView_Banner"
                      Background="Transparent"
                      CornerRadius="8"
                      ItemsSource="{x:Bind Banners}"
                      SelectionChanged="FlipView_Banner_SelectionChanged">
                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="model:BslBannerItem">
                        <Button Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BannerButton_Click">
                            <Grid>
                                <Image Source="{x:Bind Image}"
                                       Stretch="UniformToFill" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>
            <Border x:Name="Border_PipsPager"
                    Padding="10,2,10,2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource CustomOverlayAcrylicBrush}"
                    CornerRadius="8,0,8,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="TextBlock_BannerIndex"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="1/1" />
            </Border>
        </Grid>

        <Border Grid.Row="1">
            <Pivot ItemsSource="{x:Bind PostGroups}">
                <Pivot.Resources>
                    <Thickness x:Key="PivotItemMargin">0,0,0,0</Thickness>
                    <Thickness x:Key="PivotHeaderItemMargin">12,0,12,0</Thickness>
                    <Style BasedOn="{StaticResource DefaultPivotHeaderItemStyle}" TargetType="PivotHeaderItem">
                        <Setter Property="Height" Value="36" />
                        <Setter Property="FontSize" Value="16" />
                    </Style>
                </Pivot.Resources>
                <Pivot.HeaderTemplate>
                    <DataTemplate x:DataType="model:BslPostGroup">
                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Text="{x:Bind Header}" />
                    </DataTemplate>
                </Pivot.HeaderTemplate>
                <Pivot.RightHeader>
                    <Button Margin="0,0,8,0"
                            Click="MoreButton_Click"
                            Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                            ToolTipService.ToolTip="查看参考链接">
                        <FontIcon FontSize="18"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE71B;" />
                    </Button>
                </Pivot.RightHeader>
                <Pivot.ItemTemplate>
                    <DataTemplate x:DataType="model:BslPostGroup">
                        <PivotItem Margin="12,0,12,0">
                            <ScrollViewer Margin="0,0,-12,0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsRepeater Margin="0,0,16,8" ItemsSource="{x:Bind Items}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="model:BslPostItem">
                                            <Button Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="PostButton_Click"
                                                    HorizontalContentAlignment="Stretch">
                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                               Text="{x:Bind Title}"
                                                               TextTrimming="WordEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Text="{x:Bind Date}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </PivotItem>
                    </DataTemplate>
                </Pivot.ItemTemplate>
            </Pivot>
        </Border>
    </Grid>
</UserControl>
