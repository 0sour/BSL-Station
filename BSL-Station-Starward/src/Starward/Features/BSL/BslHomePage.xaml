<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.BSL.BslHomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Starward.Features.BSL"
             xmlns:launcher="using:Starward.Features.GameLauncher"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="Transparent">

        <local:BslBannerAndPost x:Name="GameBannerAndPost"
                                Margin="60,0,0,40"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom" />

        <launcher:GameBannerAndPost x:Name="MiHoYoBannerAndPost"
                                    Margin="60,0,0,40"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom" />

        <local:BslActionCluster x:Name="ActionCluster" />
    </Grid>
</sf:PageBase>
