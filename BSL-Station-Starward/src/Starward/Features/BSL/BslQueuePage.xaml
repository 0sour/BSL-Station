<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.BSL.BslQueuePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Starward.Features.BSL"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             mc:Ignorable="d">

    <sf:PageBase.Resources>
        <Style x:Key="TaskIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </sf:PageBase.Resources>

    <Grid Background="Transparent">
        <Border Margin="32,40,32,28"
                Padding="26"
                Background="{ThemeResource CustomAcrylicBrush}"
                CornerRadius="8">
            <Grid ColumnSpacing="24" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <Grid Grid.ColumnSpan="2" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Text="下载中心" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="下载、更新、预下载和修复任务会在这里统一排队。" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Click="ClearFinishedButton_Click"
                                Style="{StaticResource TaskIconButtonStyle}"
                                ToolTipService.ToolTip="清空已完成">
                            <FontIcon FontSize="15" Glyph="&#xE74D;" />
                        </Button>
                        <Button Click="RefreshButton_Click"
                                Style="{StaticResource TaskIconButtonStyle}"
                                ToolTipService.ToolTip="刷新">
                            <FontIcon FontSize="15" Glyph="&#xE72C;" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Border x:Name="AllEmptyStateBorder"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="#70161A20"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <Grid Padding="16,12"
                                  BorderBrush="#18FFFFFF"
                                  BorderThickness="0,0,0,1"
                                  ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="186" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="任务" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="进度" />
                                <TextBlock Grid.Column="2"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="状态" />
                                <TextBlock Grid.Column="3"
                                           HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="操作" />
                            </Grid>
                            <Grid MinHeight="96" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="MainScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Enabled">
                        <StackPanel Spacing="14">
                            <Border x:Name="ActiveSection"
                                    Padding="0"
                                    Background="#70161A20"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <Grid Padding="16,12"
                                          BorderBrush="#18FFFFFF"
                                          BorderThickness="0,0,0,1"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="当前任务" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{x:Bind ActiveTask.StateText, Mode=OneWay}" />
                                    </Grid>

                                    <Grid Padding="16"
                                          ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center" Spacing="3">
                                            <TextBlock FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Text="{x:Bind ActiveTask.DisplayName, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Text="{x:Bind ActiveTask.Subtitle, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MaxLines="2"
                                                       Text="{x:Bind ActiveTask.DetailText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="6">
                                            <ProgressBar Height="6"
                                                         Minimum="0"
                                                         Maximum="1"
                                                         Value="{x:Bind ActiveTask.Progress, Mode=OneWay}" />
                                            <TextBlock HorizontalAlignment="Right"
                                                       FontWeight="SemiBold"
                                                       Text="{x:Bind ActiveTask.ProgressText, Mode=OneWay}"
                                                       TextWrapping="NoWrap" />
                                            <TextBlock HorizontalAlignment="Right"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       Text="{x:Bind ActiveTask.StageProgressText, Mode=OneWay}"
                                                       TextWrapping="NoWrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Click="PauseTaskButton_Click"
                                                    CommandParameter="{x:Bind ActiveTask, Mode=OneWay}"
                                                    IsEnabled="{x:Bind ActiveTask.CanPause, Mode=OneWay}"
                                                    Style="{StaticResource TaskIconButtonStyle}"
                                                    ToolTipService.ToolTip="暂停">
                                                <FontIcon FontSize="15" Glyph="&#xE769;" />
                                            </Button>
                                            <Button Click="ContinueTaskButton_Click"
                                                    CommandParameter="{x:Bind ActiveTask, Mode=OneWay}"
                                                    IsEnabled="{x:Bind ActiveTask.CanContinue, Mode=OneWay}"
                                                    Style="{StaticResource TaskIconButtonStyle}"
                                                    ToolTipService.ToolTip="继续">
                                                <FontIcon FontSize="15" Glyph="&#xE768;" />
                                            </Button>
                                            <Button Click="StopTaskButton_Click"
                                                    CommandParameter="{x:Bind ActiveTask, Mode=OneWay}"
                                                    IsEnabled="{x:Bind ActiveTask.CanStop, Mode=OneWay}"
                                                    Style="{StaticResource TaskIconButtonStyle}"
                                                    ToolTipService.ToolTip="{x:Bind ActiveTask.StopButtonText, Mode=OneWay}">
                                                <FontIcon FontSize="15" Glyph="&#xE711;" />
                                            </Button>
                                            <Button Click="RetryTaskButton_Click"
                                                    CommandParameter="{x:Bind ActiveTask, Mode=OneWay}"
                                                    IsEnabled="{x:Bind ActiveTask.CanRetry, Mode=OneWay}"
                                                    Style="{StaticResource TaskIconButtonStyle}"
                                                    ToolTipService.ToolTip="重试">
                                                <FontIcon FontSize="15" Glyph="&#xE72C;" />
                                            </Button>
                                            <Button Click="CleanupTaskButton_Click"
                                                    CommandParameter="{x:Bind ActiveTask, Mode=OneWay}"
                                                    IsEnabled="{x:Bind ActiveTask.CanCleanup, Mode=OneWay}"
                                                    Style="{StaticResource TaskIconButtonStyle}"
                                                    ToolTipService.ToolTip="清理缓存">
                                                <FontIcon FontSize="15" Glyph="&#xE75C;" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="QueuedSection"
                                    Padding="0"
                                    Background="#50161A20"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <Grid Padding="16,12"
                                          BorderBrush="#18FFFFFF"
                                          BorderThickness="0,0,0,1"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="等待队列" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{x:Bind QueuedCountText, Mode=OneWay}" />
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind QueuedTasks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:BslDownloadCenterItem">
                                                <Grid MinHeight="92"
                                                      Padding="16,12"
                                                      BorderBrush="#14FFFFFF"
                                                      BorderThickness="0,0,0,1"
                                                      ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="82" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Text="{x:Bind DisplayName}" />
                                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   Text="{x:Bind Subtitle}" />
                                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   MaxLines="2"
                                                                   Text="{x:Bind DetailText}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="WrapWholeWords" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="6">
                                                        <ProgressBar Height="5"
                                                                     Minimum="0"
                                                                     Maximum="1"
                                                                     Value="{x:Bind Progress}" />
                                                        <TextBlock HorizontalAlignment="Right"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   Text="{x:Bind ProgressText}"
                                                                   TextWrapping="NoWrap" />
                                                        <TextBlock HorizontalAlignment="Right"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   Text="{x:Bind StageProgressText}"
                                                                   TextWrapping="NoWrap" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Text="{x:Bind StateText}"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <StackPanel Grid.Column="3"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Click="PauseTaskButton_Click"
                                                                CommandParameter="{x:Bind}"
                                                                IsEnabled="{x:Bind CanPause}"
                                                                Style="{StaticResource TaskIconButtonStyle}"
                                                                ToolTipService.ToolTip="暂停">
                                                            <FontIcon FontSize="15" Glyph="&#xE769;" />
                                                        </Button>
                                                        <Button Click="ContinueTaskButton_Click"
                                                                CommandParameter="{x:Bind}"
                                                                IsEnabled="{x:Bind CanContinue}"
                                                                Style="{StaticResource TaskIconButtonStyle}"
                                                                ToolTipService.ToolTip="继续">
                                                            <FontIcon FontSize="15" Glyph="&#xE768;" />
                                                        </Button>
                                                        <Button Click="StopTaskButton_Click"
                                                                CommandParameter="{x:Bind}"
                                                                IsEnabled="{x:Bind CanStop}"
                                                                Style="{StaticResource TaskIconButtonStyle}"
                                                                ToolTipService.ToolTip="{x:Bind StopButtonText}">
                                                            <FontIcon FontSize="15" Glyph="&#xE711;" />
                                                        </Button>
                                                        <Button Click="RetryTaskButton_Click"
                                                                CommandParameter="{x:Bind}"
                                                                IsEnabled="{x:Bind CanRetry}"
                                                                Style="{StaticResource TaskIconButtonStyle}"
                                                                ToolTipService.ToolTip="重试">
                                                            <FontIcon FontSize="15" Glyph="&#xE72C;" />
                                                        </Button>
                                                        <Button Click="RemoveTaskButton_Click"
                                                                CommandParameter="{x:Bind}"
                                                                IsEnabled="{x:Bind CanRemove}"
                                                                Style="{StaticResource TaskIconButtonStyle}"
                                                                ToolTipService.ToolTip="移除">
                                                            <FontIcon FontSize="15" Glyph="&#xE74D;" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              VerticalScrollMode="Enabled">
                    <StackPanel Spacing="14">
                        <Border Padding="0"
                                Background="#70161A20"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Padding="14" Spacing="4">
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{x:Bind ActiveCountText, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="正在处理" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Padding="14"
                                            BorderBrush="#18FFFFFF"
                                            BorderThickness="1,0,1,0"
                                            Spacing="4">
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{x:Bind QueuedCountText, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="等待队列" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Padding="14" Spacing="4">
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{x:Bind CompletedCountText, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="历史" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="CompletedSection"
                                Padding="0"
                                Background="#50161A20"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <Grid Padding="16,12"
                                      BorderBrush="#18FFFFFF"
                                      BorderThickness="0,0,0,1"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontWeight="SemiBold" Text="历史任务" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{x:Bind CompletedCountText, Mode=OneWay}" />
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind CompletedTasks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:BslDownloadCenterItem">
                                            <StackPanel Padding="14"
                                                        BorderBrush="#14FFFFFF"
                                                        BorderThickness="0,0,0,1"
                                                        Spacing="8">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Spacing="2">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{x:Bind DisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   Text="{x:Bind Subtitle}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Text="{x:Bind StateText}" />
                                                </Grid>

                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           MaxLines="3"
                                                           Text="{x:Bind DetailText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="WrapWholeWords" />

                                                <StackPanel HorizontalAlignment="Right"
                                                            Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Click="RetryTaskButton_Click"
                                                            CommandParameter="{x:Bind}"
                                                            IsEnabled="{x:Bind CanRetry}"
                                                            Style="{StaticResource TaskIconButtonStyle}"
                                                            ToolTipService.ToolTip="重试">
                                                        <FontIcon FontSize="15" Glyph="&#xE72C;" />
                                                    </Button>
                                                    <Button Click="CleanupTaskButton_Click"
                                                            CommandParameter="{x:Bind}"
                                                            IsEnabled="{x:Bind CanCleanup}"
                                                            Style="{StaticResource TaskIconButtonStyle}"
                                                            ToolTipService.ToolTip="清理缓存">
                                                        <FontIcon FontSize="15" Glyph="&#xE75C;" />
                                                    </Button>
                                                    <Button Click="RemoveTaskButton_Click"
                                                            CommandParameter="{x:Bind}"
                                                            IsEnabled="{x:Bind CanRemove}"
                                                            Style="{StaticResource TaskIconButtonStyle}"
                                                            ToolTipService.ToolTip="移除">
                                                        <FontIcon FontSize="15" Glyph="&#xE74D;" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</sf:PageBase>
